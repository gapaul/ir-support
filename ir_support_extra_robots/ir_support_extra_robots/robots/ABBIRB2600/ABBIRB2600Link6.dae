<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset><unit name="meter" meter="1"/><up_axis>Z_UP</up_axis></asset>
  <library_effects>
    <effect id="grey-effect"><profile_COMMON><technique sid="common"><lambert>
      <diffuse><color>0.18 0.18 0.18 1</color></diffuse>
    </lambert></technique></profile_COMMON></effect>
  </library_effects>
  <library_materials>
    <material id="grey-material" name="grey"><instance_effect url="#grey-effect"/></material>
  </library_materials>
  <library_geometries>
    <geometry id="placeholder-geometry" name="placeholder">
      <mesh>
        <source id="placeholder-positions">
          <float_array id="placeholder-positions-array" count="24">-0.017500 -0.017500 -0.017500 0.017500 -0.017500 -0.017500 0.017500 0.017500 -0.017500 -0.017500 0.017500 -0.017500 -0.017500 -0.017500 0.017500 0.017500 -0.017500 0.017500 0.017500 0.017500 0.017500 -0.017500 0.017500 0.017500</float_array>
          <technique_common><accessor source="#placeholder-positions-array" count="8" stride="3">
            <param name="X" type="float"/><param name="Y" type="float"/><param name="Z" type="float"/>
          </accessor></technique_common>
        </source>
        <vertices id="placeholder-vertices"><input semantic="POSITION" source="#placeholder-positions"/></vertices>
        <triangles material="grey-material" count="12"><input semantic="VERTEX" source="#placeholder-vertices" offset="0"/><p>0 1 2 0 2 3 4 6 5 4 7 6 0 4 5 0 5 1 1 5 6 1 6 2 2 6 7 2 7 3 3 7 4 3 4 0</p></triangles>
      </mesh>
    </geometry>
  </library_geometries>
  <library_visual_scenes>
    <visual_scene id="Scene" name="Scene">
      <node id="placeholder" name="placeholder"><instance_geometry url="#placeholder-geometry">
        <bind_material><technique_common><instance_material symbol="grey-material" target="#grey-material"/></technique_common></bind_material>
      </instance_geometry></node>
    </visual_scene>
  </library_visual_scenes>
  <scene><instance_visual_scene url="#Scene"/></scene>
</COLLADA>
